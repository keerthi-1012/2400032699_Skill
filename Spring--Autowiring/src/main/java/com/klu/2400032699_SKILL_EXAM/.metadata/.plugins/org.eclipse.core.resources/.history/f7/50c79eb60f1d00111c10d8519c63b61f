package com.klef.fsad.exam;

import javax.persistence.*;

@Entity
@Table(name="booking")
public class Booking
{

@Id
@GeneratedValue(strategy = GenerationType.IDENTITY)
public int id;

public String name;
public String date;
public String status;

public Booking(){}

public Booking(String name,String date,String status)
{
this.name=name;
this.date=date;
this.status=status;
}
}